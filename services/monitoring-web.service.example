[Unit]
Description=Monitoring Flask Web Server
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/monitoring-web

# Flask bind settings
Environment="HOST=0.0.0.0"
Environment="PORT=5000"

# true = Flask draait met self-signed HTTPS via ssl_context='adhoc'
# false = Flask draait met HTTP
Environment="USE_ADHOC_SSL=true"

# Flask session secret
Environment="SECRET_KEY=CHANGE_THIS_SECRET"

# Amazon OAuth settings
Environment="AMAZON_CLIENT_ID=CHANGE_THIS"
Environment="AMAZON_CLIENT_SECRET=CHANGE_THIS"
Environment="EXTERNAL_SCHEME=https"
Environment="EXTERNAL_HOST=192.168.178.204:5000"

# Agent security settings
# Fernet key:
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
Environment="AGENT_ENCRYPTION_KEY=CHANGE_THIS_FERNET_KEY"

# HMAC secret:
# openssl rand -hex 32
Environment="AGENT_HMAC_SECRET=CHANGE_THIS_HMAC_SECRET"

# Max allowed clock difference for signed agent requests
Environment="AGENT_MAX_CLOCK_SKEW_SECONDS=300"

ExecStart=/usr/bin/python3 /opt/monitoring-web/app.py

Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target