"""Configuration file example for the monitoring web server.

Copy this file to config.py on the actual server.

Do not commit real secrets to Git. Secrets such as OAuth client secrets,
Flask secret keys and agent encryption keys should be set through environment
variables or stored only in a local config.py file.
"""

import os

BASE_DIR = os.path.abspath(os.path.dirname(__file__))

LOG_DIR = os.path.join(BASE_DIR, "logs")
DATA_DIR = os.path.join(BASE_DIR, "data")
DB_FILE = os.path.join(DATA_DIR, "monitoring.sqlite3")
SERVER_LOG = os.path.join(LOG_DIR, "server.log")

HOST = os.environ.get("HOST", "0.0.0.0")
PORT = int(os.environ.get("PORT", "5000"))

MAX_ROWS_PER_AGENT = int(os.environ.get("MAX_ROWS_PER_AGENT", "25"))
MAX_STORED_ROWS_PER_AGENT = int(os.environ.get("MAX_STORED_ROWS_PER_AGENT", "100"))
REFRESH_INTERVAL_MS = int(os.environ.get("REFRESH_INTERVAL_MS", "10000"))

# For a self-signed Flask HTTPS test setup, keep this true.
# For plain HTTP, set this to false.
USE_ADHOC_SSL = os.environ.get("USE_ADHOC_SSL", "true").lower() == "true"

# Flask session secret
SECRET_KEY = os.environ.get("SECRET_KEY", "")

# Amazon OAuth
AMAZON_CLIENT_ID = os.environ.get("AMAZON_CLIENT_ID", "")
AMAZON_CLIENT_SECRET = os.environ.get("AMAZON_CLIENT_SECRET", "")

EXTERNAL_SCHEME = os.environ.get("EXTERNAL_SCHEME", "https")
EXTERNAL_HOST = os.environ.get("EXTERNAL_HOST", "192.168.178.204:5000")
AMAZON_REDIRECT_URI = f"{EXTERNAL_SCHEME}://{EXTERNAL_HOST}/auth/amazon/callback"

# Agent security
AGENT_ENCRYPTION_KEY = os.environ.get("AGENT_ENCRYPTION_KEY", "")
AGENT_HMAC_SECRET = os.environ.get("AGENT_HMAC_SECRET", "")
AGENT_MAX_CLOCK_SKEW_SECONDS = int(os.environ.get("AGENT_MAX_CLOCK_SKEW_SECONDS", "300"))