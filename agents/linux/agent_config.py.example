"""Configuration for the secure Linux monitoring agent."""

import os

SERVER_URL = os.environ.get("SERVER_URL", "https://192.168.178.204:5000/api/monitor")
INTERVAL_SECONDS = int(os.environ.get("INTERVAL_SECONDS", "5"))
LOG_FILE = os.environ.get("LOG_FILE", "/opt/monitoring-agent/agent.log")

AGENT_ID = os.environ.get("AGENT_ID", "linux-agent-01")
AGENT_VERSION = "4.0-secure-linux"

AGENT_ENCRYPTION_KEY = os.environ.get("AGENT_ENCRYPTION_KEY", "")
AGENT_HMAC_SECRET = os.environ.get("AGENT_HMAC_SECRET", "")

VERIFY_TLS = os.environ.get("VERIFY_TLS", "false").lower() == "true"

DISK_PATH = os.environ.get("DISK_PATH", "/")
IP_DETECTION_TARGET = os.environ.get("IP_DETECTION_TARGET", "192.168.178.1")
